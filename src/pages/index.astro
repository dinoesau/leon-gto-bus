---
import BusMap from '../components/BusMap.astro';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rutas de Bus — A-03 & A-75</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-title">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="1" y="3" width="15" height="13" rx="2"/>
            <path d="M16 8h4l3 3v5h-7V8z"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <div>
            <h1>Rutas de Bus</h1>
            <p>León, Guanajuato</p>
          </div>
        </div>
        <div class="route-badges">
          <span class="badge badge-a03">A-03</span>
          <span class="badge badge-a75">A-75</span>
        </div>
      </div>
    </header>

    <main>
      <BusMap />
    </main>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: #f0f4f8;
    color: #1a202c;
  }

  body {
    display: flex;
    flex-direction: column;
  }

  header {
    background: white;
    border-bottom: 1px solid #e2e8f0;
    padding: 0 24px;
    height: 64px;
    flex-shrink: 0;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .header-inner {
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-title {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #2d3748;
  }

  .header-title h1 {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
  }

  .header-title p {
    font-size: 12px;
    color: #718096;
  }

  .route-badges {
    display: flex;
    gap: 8px;
  }

  .badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .badge-a03 {
    background: #FEE2E2;
    color: #C53030;
  }

  .badge-a75 {
    background: #DBEAFE;
    color: #1E40AF;
  }

  main {
    flex: 1;
    padding: 20px 24px;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }
</style>
